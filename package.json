{
  "name": "@finografic/deps-policy",
  "version": "0.1.0",
  "description": "Central dependency policy for the @finografic ecosystem",
  "keywords": [
    "dependency-management",
    "deps-policy",
    "finografic",
    "genx:internal",
    "genx:type:config"
  ],
  "homepage": "https://github.com/finografic/deps-policy",
  "bugs": {
    "url": "https://github.com/finografic/deps-policy/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/deps-policy.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./policy": {
      "types": "./dist/policy/index.d.mts",
      "default": "./dist/policy/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "packageManager": "pnpm@10.32.1"
}
