{
  "name": "@finografic/deps-policy",
  "version": "0.15.7",
  "description": "Central dependency policy for the @finografic ecosystem",
  "keywords": [
    "dependency-management",
    "deps-policy",
    "finografic",
    "genx:internal",
    "genx:type:config"
  ],
  "homepage": "https://github.com/finografic/deps-policy",
  "bugs": {
    "url": "https://github.com/finografic/deps-policy/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/deps-policy.git"
  },
  "files": [
    "dist",
    "docs/deps"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "policy": "./dist/bin/policy.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./policy": {
      "types": "./dist/policy/cli.d.mts",
      "default": "./dist/policy/cli.mjs"
    },
    "./deps.types": {
      "types": "./dist/deps.types.d.mts",
      "default": "./dist/deps.types.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "update": "pnpm policy:update && tsdown",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm lint:fix && pnpm typecheck",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/deps-policy --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:cli-kit": "pnpm update @finografic/cli-kit --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest",
    "update:eslint-config": "pnpm update @finografic/eslint-config --latest",
    "update:md-lint": "pnpm update @finografic/md-lint --latest",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest",
    "update:finografic:all": "pnpm update:cli-kit && pnpm update:oxfmt-config && pnpm update:md-lint && pnpm update:project-scripts",
    "update:deps:all": "pnpm update --latest",
    "·········· POLICY UPDATER": "············································",
    "policy:outdated": "tsx src/deps-cli/cli.ts outdated",
    "policy:update": "tsx src/deps-cli/cli.ts update",
    "policy:audit": "tsx src/deps-cli/cli.ts audit",
    "·········· UTILS": "·····················································",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@finografic/cli-kit": "^1.1.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@clack/core": "1.2.0",
    "@clack/prompts": "^1.2.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.2",
    "@finografic/eslint-config": "^9.18.4",
    "@finografic/md-lint": "^0.9.6",
    "@finografic/oxfmt-config": "^1.11.1",
    "@finografic/project-scripts": "^1.3.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "9.39.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "picocolors": "^1.1.1",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.3.0"
  },
  "LOCAL_DEP_EXAMPLE": {
    "@finografic/cli-kit": "^1.1.1",
    "@finografic/cli-kit_LOCAL": "file:/Users/justin/repos-finografic/@finografic-cli-kit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,md,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
