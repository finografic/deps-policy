{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "deps.types": ["./src/deps.types.ts"],
      "policy/*": ["./src/policy/*"],
      "deps-cli/*": ["./src/deps-cli/*"],
      "commands": ["./src/deps-cli/commands/index.ts"],
      "commands/*": ["./src/deps-cli/commands/*"],
      "output/*": ["./src/deps-cli/output/*"],
      "utils/*": ["./src/deps-cli/utils/*"],
      "types/*": ["./src/deps-cli/types/*"],
      "*": ["./src/deps-cli/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
